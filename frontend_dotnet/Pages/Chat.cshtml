@page
@model frontend_dotnet.Pages.ChatModel
@{
    ViewData["Title"] = "Chat";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" />
}

<div class="chat-page d-flex flex-column" style="height: calc(100vh - 160px);">
    <div id="messages" class="chat-container flex-grow-1 overflow-auto p-3 bg-white">
        <!-- 消息将由前端脚本动态插入 -->
    </div>

    <div class="chat-input p-3 border-top bg-light">
        <form id="chat-form" class="d-flex" onsubmit="return false;">
            <textarea id="chat-input" class="form-control" placeholder="输入消息，按发送或回车" rows="2"></textarea>
            <button id="send-btn" class="btn btn-primary ms-2">发送</button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat.js"></script>
}
